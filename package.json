  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/piLeoni/tmt88v-print"
  },
  "dependencies": {
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
